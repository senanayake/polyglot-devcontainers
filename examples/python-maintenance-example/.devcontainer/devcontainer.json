{
  "name": "python-maintenance-example",
  "image": "ghcr.io/senanayake/polyglot-devcontainers-python-node:main",
  "postCreateCommand": "bash ../../scripts/install_runtime_docs.sh ../../man/man7 && task init && pre-commit install",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "python.analysis.typeCheckingMode": "basic"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker"
      ]
    }
  },
  "remoteUser": "vscode"
}
