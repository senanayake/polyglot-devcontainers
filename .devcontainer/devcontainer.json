{
  "name": "polyglot-devcontainers-maintainer",
  "build": {
    "dockerfile": "Containerfile",
    "context": ".."
  },
  "postCreateCommand": "bash scripts/install_runtime_docs.sh man/man7 && task init && pre-commit install",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/workspaces/polyglot-devcontainers/examples/python-example/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "examples/python-example/tests"
        ],
        "python.analysis.typeCheckingMode": "basic"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "editorconfig.editorconfig"
      ]
    }
  },
  "remoteUser": "vscode"
}
