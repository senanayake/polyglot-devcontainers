{
  "name": "polyglot-devcontainers-maintainer",
  "image": "ghcr.io/senanayake/polyglot-devcontainers-maintainer:main",
  "runArgs": ["--privileged"],
  "postCreateCommand": "bash /usr/local/share/polyglot-devcontainers/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/workspaces/polyglot-devcontainers/examples/python-example/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "examples/python-example/tests"
        ],
        "python.analysis.typeCheckingMode": "basic"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "editorconfig.editorconfig"
      ]
    }
  },
  "remoteUser": "vscode"
}
