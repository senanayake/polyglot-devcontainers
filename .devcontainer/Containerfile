FROM mcr.microsoft.com/devcontainers/python:1-3.12-bookworm

LABEL org.opencontainers.image.source="https://github.com/senanayake/polyglot-devcontainers" \
      org.opencontainers.image.description="Reference Python engineering container for polyglot-devcontainers." \
      org.opencontainers.image.licenses="MIT"

USER root

COPY features /tmp/features

RUN bash /tmp/features/security-baseline/install.sh \
    && bash /tmp/features/python-engineering/install.sh \
    && bash /tmp/features/agent-runtime/install.sh \
    && rm -rf /tmp/features

USER vscode
