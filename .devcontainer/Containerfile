FROM mcr.microsoft.com/devcontainers/java:1-21-bookworm@sha256:0af991049cded4b8d5a90d2614289ceec390779ad6a3e4b70957e2b4f3bb1230 AS java_base

FROM mcr.microsoft.com/devcontainers/python:1-3.12-bookworm@sha256:7876580dc67fd460fd962f004cbeb480027e9bbc0657096f1087db11f9eaff39

LABEL org.opencontainers.image.source="https://github.com/senanayake/polyglot-devcontainers" \
      org.opencontainers.image.description="Maintainer and CI validation container for polyglot-devcontainers." \
      org.opencontainers.image.licenses="MIT" \
      devcontainer.metadata="[{\"postCreateCommand\":\"bash /usr/local/share/polyglot-devcontainers/post-create.sh\",\"customizations\":{\"vscode\":{\"settings\":{\"editor.formatOnSave\":true,\"python.defaultInterpreterPath\":\"/workspaces/polyglot-devcontainers/examples/python-example/.venv/bin/python\",\"python.testing.pytestEnabled\":true,\"python.testing.pytestArgs\":[\"examples/python-example/tests\"],\"python.analysis.typeCheckingMode\":\"basic\"},\"extensions\":[\"ms-python.python\",\"charliermarsh.ruff\",\"ms-python.mypy-type-checker\",\"editorconfig.editorconfig\"]}},\"remoteUser\":\"vscode\"}]"

USER root

ENV POLYGLOT_CONTAINER_ROLE=maintainer

COPY --from=java_base /usr/lib/jvm/msopenjdk-current /usr/lib/jvm/msopenjdk-current

COPY .devcontainer/post-create.sh /usr/local/share/polyglot-devcontainers/post-create.sh
COPY scripts/install_runtime_docs.sh /tmp/install_runtime_docs.sh
COPY man/man7 /tmp/runtime-docs

COPY features /tmp/features

ARG NODESOURCE_KEY_SHA256=b42e0321dabdc24e892115da705cf061167eac12a317f23d329862d0aa0a271d # gitleaks:allow

RUN rm -f /etc/apt/sources.list.d/yarn.list \
    && chmod 0755 /usr/local/share/polyglot-devcontainers/post-create.sh \
    && chmod 0755 /tmp/install_runtime_docs.sh \
    && apt-get update \
    && apt-get -y dist-upgrade \
    && apt-get install -y --no-install-recommends ca-certificates curl docker.io git gnupg less man-db \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSLo /tmp/nodesource.key https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    && echo "${NODESOURCE_KEY_SHA256}  /tmp/nodesource.key" | sha256sum -c - \
    && gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg /tmp/nodesource.key \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && bash /tmp/install_runtime_docs.sh /tmp/runtime-docs \
    && ln -sf /usr/lib/jvm/msopenjdk-current/bin/java /usr/local/bin/java \
    && ln -sf /usr/lib/jvm/msopenjdk-current/bin/javac /usr/local/bin/javac \
    && usermod -aG docker vscode \
    && rm -rf /tmp/nodesource.key /tmp/install_runtime_docs.sh /tmp/runtime-docs /var/lib/apt/lists/* /etc/apt/keyrings /etc/apt/sources.list.d/nodesource.list

RUN bash /tmp/features/security-baseline/install.sh \
    && bash /tmp/features/python-engineering/install.sh \
    && bash /tmp/features/node-engineering/install.sh \
    && bash /tmp/features/java-engineering/install.sh \
    && bash /tmp/features/agent-runtime/install.sh \
    && rm -rf /tmp/features

USER vscode
