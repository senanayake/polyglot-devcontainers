FROM mcr.microsoft.com/devcontainers/python:1-3.12-bookworm

LABEL devcontainer.metadata="[{\"postCreateCommand\":\"task init && pre-commit install\",\"customizations\":{\"vscode\":{\"settings\":{\"editor.formatOnSave\":true,\"python.defaultInterpreterPath\":\"/workspaces/$${localWorkspaceFolderBasename}/.venv/bin/python\",\"python.testing.pytestEnabled\":true,\"python.testing.pytestArgs\":[\"backend/tests\"],\"python.analysis.typeCheckingMode\":\"basic\",\"eslint.validate\":[\"javascript\",\"javascriptreact\",\"typescript\",\"typescriptreact\"],\"typescript.tsdk\":\"frontend/node_modules/typescript/lib\"},\"extensions\":[\"ms-python.python\",\"charliermarsh.ruff\",\"ms-python.mypy-type-checker\",\"dbaeumer.vscode-eslint\",\"esbenp.prettier-vscode\",\"vitest.explorer\"]}},\"remoteUser\":\"vscode\"}]"

USER root

ARG TASK_VERSION=3.49.1
ARG GITLEAKS_VERSION=8.30.0
ARG PRE_COMMIT_VERSION=4.2.0
ARG UV_VERSION=0.8.13
ARG PNPM_VERSION=10.7.0

RUN rm -f /etc/apt/sources.list.d/yarn.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git gnupg jq ripgrep shellcheck tar unzip \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && curl -sSL https://taskfile.dev/install.sh | sh -s -- -d -b /usr/local/bin "v${TASK_VERSION}" \
    && curl -sSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" \
    | tar -xz -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks \
    && python3 -m pip install --no-cache-dir "pre-commit==${PRE_COMMIT_VERSION}" "uv==${UV_VERSION}" \
    && corepack enable \
    && corepack prepare "pnpm@${PNPM_VERSION}" --activate \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf /var/lib/apt/lists/* /etc/apt/keyrings /etc/apt/sources.list.d/nodesource.list

USER vscode
