FROM mcr.microsoft.com/devcontainers/base:1-bookworm@sha256:ce2e9e611939e611b737362c045bb6d3449bb3efb84898525d724aace1737b90

LABEL devcontainer.metadata="[{\"postCreateCommand\":\"bash /usr/local/share/polyglot-devcontainers/post-create.sh\",\"customizations\":{\"vscode\":{\"settings\":{\"editor.formatOnSave\":true,\"files.associations\":{\"*.d2\":\"plaintext\"}}}},\"remoteUser\":\"vscode\"}]"

USER root

ENV POLYGLOT_BOOTSTRAP_TEMPLATE=diagram-secure

ARG TASK_VERSION=3.50.0
ARG GITLEAKS_VERSION=8.30.1

COPY templates/diagram-secure/.devcontainer/post-create.sh /usr/local/share/polyglot-devcontainers/post-create.sh
COPY templates/diagram-secure/.devcontainer/bootstrap-workspace.sh /usr/local/bin/polyglot-bootstrap-workspace
COPY templates/diagram-secure/.devcontainer/task-wrapper.sh /usr/local/bin/task
COPY templates/diagram-secure /usr/local/share/polyglot-devcontainers/bootstrap/diagram-secure
COPY scripts/scaffold_project_conventions.sh /usr/local/bin/polyglot-scaffold-project-conventions
COPY assets/starter-scaffold /usr/local/share/polyglot-devcontainers/starter-scaffold
COPY scripts/install_runtime_docs.sh /tmp/install_runtime_docs.sh
COPY man/man7 /tmp/runtime-docs
COPY features /tmp/features

RUN chmod 0755 /usr/local/share/polyglot-devcontainers/post-create.sh \
    && chmod 0755 /usr/local/bin/polyglot-bootstrap-workspace /usr/local/bin/task /usr/local/bin/polyglot-scaffold-project-conventions \
    && chmod 0755 /tmp/install_runtime_docs.sh \
    && rm -rf /usr/local/share/polyglot-devcontainers/bootstrap/diagram-secure/.devcontainer \
    && apt-get update \
    && apt-get -y dist-upgrade \
    && apt-get install -y --no-install-recommends ca-certificates curl git less man-db tar \
    && arch="$(dpkg --print-architecture)" \
    && case "${arch}" in \
        amd64) task_archive="task_linux_amd64.tar.gz"; gitleaks_archive="gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" ;; \
        arm64) task_archive="task_linux_arm64.tar.gz"; gitleaks_archive="gitleaks_${GITLEAKS_VERSION}_linux_arm64.tar.gz" ;; \
        *) echo "Unsupported architecture: ${arch}" >&2; exit 1 ;; \
      esac \
    && tmpdir="$(mktemp -d)" \
    && curl --retry 5 --retry-all-errors --retry-delay 2 -fsSLo "${tmpdir}/${task_archive}" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/${task_archive}" \
    && curl --retry 5 --retry-all-errors --retry-delay 2 -fsSLo "${tmpdir}/task_checksums.txt" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/task_checksums.txt" \
    && task_checksum_line=$(grep "${task_archive}" "${tmpdir}/task_checksums.txt") \
    && if [ -z "${task_checksum_line}" ]; then \
         echo "ERROR: Checksum not found for ${task_archive}" >&2; \
         exit 1; \
       fi \
    && (cd "${tmpdir}" && echo "${task_checksum_line}" | sha256sum -c -) \
    && mkdir -p /usr/local/libexec/polyglot-devcontainers \
    && tar -xzf "${tmpdir}/${task_archive}" -C /usr/local/libexec/polyglot-devcontainers task \
    && mv /usr/local/libexec/polyglot-devcontainers/task /usr/local/libexec/polyglot-devcontainers/task-real \
    && curl --retry 5 --retry-all-errors --retry-delay 2 -fsSLo "${tmpdir}/${gitleaks_archive}" "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/${gitleaks_archive}" \
    && curl --retry 5 --retry-all-errors --retry-delay 2 -fsSLo "${tmpdir}/gitleaks_checksums.txt" "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_checksums.txt" \
    && gitleaks_checksum_line=$(grep "${gitleaks_archive}" "${tmpdir}/gitleaks_checksums.txt") \
    && if [ -z "${gitleaks_checksum_line}" ]; then \
         echo "ERROR: Checksum not found for ${gitleaks_archive}" >&2; \
         exit 1; \
       fi \
    && (cd "${tmpdir}" && echo "${gitleaks_checksum_line}" | sha256sum -c -) \
    && tar -xzf "${tmpdir}/${gitleaks_archive}" -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks \
    && bash /tmp/features/diagram-rendering/install.sh \
    && bash /tmp/install_runtime_docs.sh /tmp/runtime-docs \
    && rm -rf "${tmpdir}" /tmp/install_runtime_docs.sh /tmp/runtime-docs /tmp/features /var/lib/apt/lists/*

USER vscode
