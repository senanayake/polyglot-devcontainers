FROM mcr.microsoft.com/devcontainers/java:1-21-bookworm@sha256:0af991049cded4b8d5a90d2614289ceec390779ad6a3e4b70957e2b4f3bb1230

LABEL devcontainer.metadata="[{\"postCreateCommand\":\"bash /usr/local/share/polyglot-devcontainers/post-create.sh\",\"customizations\":{\"vscode\":{\"settings\":{\"editor.formatOnSave\":true,\"java.configuration.updateBuildConfiguration\":\"automatic\",\"java.import.gradle.enabled\":true,\"[java]\":{\"editor.defaultFormatter\":\"redhat.java\"}},\"extensions\":[\"vscjava.vscode-java-pack\",\"vscjava.vscode-gradle\"]}},\"remoteUser\":\"vscode\"}]"

USER root

ENV POLYGLOT_BOOTSTRAP_TEMPLATE=java-secure

ARG TASK_VERSION=3.49.1
ARG GITLEAKS_VERSION=8.30.1
ARG GRADLE_VERSION=9.1.0

COPY templates/java-secure/.devcontainer/post-create.sh /usr/local/share/polyglot-devcontainers/post-create.sh
COPY templates/java-secure/.devcontainer/bootstrap-workspace.sh /usr/local/bin/polyglot-bootstrap-workspace
COPY templates/java-secure/.devcontainer/task-wrapper.sh /usr/local/bin/task
COPY templates/java-secure /usr/local/share/polyglot-devcontainers/bootstrap/java-secure
COPY scripts/install_runtime_docs.sh /tmp/install_runtime_docs.sh
COPY man/man7 /tmp/runtime-docs

RUN rm -f /etc/apt/sources.list.d/yarn.list \
    && chmod 0755 /usr/local/share/polyglot-devcontainers/post-create.sh \
    && chmod 0755 /usr/local/bin/polyglot-bootstrap-workspace /usr/local/bin/task \
    && chmod 0755 /tmp/install_runtime_docs.sh \
    && rm -rf /usr/local/share/polyglot-devcontainers/bootstrap/java-secure/.devcontainer \
    && apt-get update \
    && apt-get -y dist-upgrade \
    && apt-get install -y --no-install-recommends ca-certificates curl git gnupg jq less man-db ripgrep shellcheck tar unzip \
    && rm -rf /var/lib/apt/lists/* \
    && arch="$(dpkg --print-architecture)" \
    && case "${arch}" in \
        amd64) task_archive="task_linux_amd64.tar.gz"; gitleaks_archive="gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" ;; \
        arm64) task_archive="task_linux_arm64.tar.gz"; gitleaks_archive="gitleaks_${GITLEAKS_VERSION}_linux_arm64.tar.gz" ;; \
        *) echo "Unsupported architecture: ${arch}" >&2; exit 1 ;; \
      esac \
    && tmpdir="$(mktemp -d)" \
    && curl -fsSLo "${tmpdir}/${task_archive}" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/${task_archive}" \
    && curl -fsSLo "${tmpdir}/task_checksums.txt" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/task_checksums.txt" \
    && task_checksum_line=$(grep "${task_archive}" "${tmpdir}/task_checksums.txt") \
    && if [ -z "$task_checksum_line" ]; then \
         echo "ERROR: Checksum not found for ${task_archive}" >&2; \
         exit 1; \
       fi \
    && (cd "${tmpdir}" && echo "$task_checksum_line" | sha256sum -c -) \
    && mkdir -p /usr/local/libexec/polyglot-devcontainers \
    && tar -xzf "${tmpdir}/${task_archive}" -C /usr/local/libexec/polyglot-devcontainers task \
    && mv /usr/local/libexec/polyglot-devcontainers/task /usr/local/libexec/polyglot-devcontainers/task-real \
    && curl -fsSLo "${tmpdir}/${gitleaks_archive}" "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/${gitleaks_archive}" \
    && curl -fsSLo "${tmpdir}/gitleaks_checksums.txt" "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_checksums.txt" \
    && gitleaks_checksum_line=$(grep "${gitleaks_archive}" "${tmpdir}/gitleaks_checksums.txt") \
    && if [ -z "$gitleaks_checksum_line" ]; then \
         echo "ERROR: Checksum not found for ${gitleaks_archive}" >&2; \
         exit 1; \
       fi \
    && (cd "${tmpdir}" && echo "$gitleaks_checksum_line" | sha256sum -c -) \
    && tar -xzf "${tmpdir}/${gitleaks_archive}" -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks \
    && curl -fsSLo /tmp/gradle.zip "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" \
    && curl -fsSLo /tmp/gradle.zip.sha256 "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip.sha256" \
    && echo "$(cat /tmp/gradle.zip.sha256)  /tmp/gradle.zip" | sha256sum -c - \
    && rm -rf "/opt/gradle-${GRADLE_VERSION}" \
    && unzip -q /tmp/gradle.zip -d /opt \
    && ln -sf "/opt/gradle-${GRADLE_VERSION}/bin/gradle" /usr/local/bin/gradle \
    && rm -f /tmp/gradle.zip /tmp/gradle.zip.sha256 \
    && mkdir -p /usr/share/keyrings \
    && curl -fsSL https://aquasecurity.github.io/trivy-repo/deb/public.key \
    | gpg --dearmor --batch --yes -o /usr/share/keyrings/trivy.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" \
    > /etc/apt/sources.list.d/trivy.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends trivy \
    && bash /tmp/install_runtime_docs.sh /tmp/runtime-docs \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf "${tmpdir}" /tmp/install_runtime_docs.sh /tmp/runtime-docs

USER vscode
