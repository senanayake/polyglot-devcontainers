FROM debian:trixie-slim@sha256:109e2c65005bf160609e4ba6acf7783752f8502ad218e298253428690b9eaa4b

LABEL org.opencontainers.image.source="https://github.com/senanayake/polyglot-devcontainers" \
      org.opencontainers.image.description="LaTeX document build container for reproducible academic paper workflows." \
      org.opencontainers.image.licenses="MIT" \
      devcontainer.metadata="[{\"postCreateCommand\":\"bash /usr/local/share/polyglot-devcontainers/post-create.sh\",\"customizations\":{\"vscode\":{\"settings\":{\"editor.formatOnSave\":true,\"latex-workshop.latex.recipe.default\":\"latexmk (latexmkrc)\",\"latex-workshop.latex.outDir\":\"%DIR%\"},\"extensions\":[\"james-yu.latex-workshop\",\"streetsidesoftware.code-spell-checker\"]}},\"remoteUser\":\"vscode\"}]"

USER root

ENV POLYGLOT_BOOTSTRAP_TEMPLATE=latex \
    HOME=/home/vscode \
    USER=vscode \
    SHELL=/bin/bash

ARG TASK_VERSION=3.49.1
ARG GITLEAKS_VERSION=8.30.1
ARG PRE_COMMIT_VERSION=4.2.0

COPY templates/latex/.devcontainer/post-create.sh /usr/local/share/polyglot-devcontainers/post-create.sh
COPY templates/latex/.devcontainer/bootstrap-workspace.sh /usr/local/bin/polyglot-bootstrap-workspace
COPY templates/latex/.devcontainer/task-wrapper.sh /usr/local/bin/task
COPY templates/latex /usr/local/share/polyglot-devcontainers/bootstrap/latex
COPY scripts/install_runtime_docs.sh /tmp/install_runtime_docs.sh
COPY man/man7 /tmp/runtime-docs

RUN chmod 0755 /usr/local/share/polyglot-devcontainers/post-create.sh \
    && chmod 0755 /usr/local/bin/polyglot-bootstrap-workspace /usr/local/bin/task \
    && chmod 0755 /tmp/install_runtime_docs.sh \
    && rm -rf /usr/local/share/polyglot-devcontainers/bootstrap/latex/.devcontainer \
    && groupadd --gid 1000 vscode \
    && useradd --uid 1000 --gid 1000 -m -s /bin/bash vscode \
    && apt-get update \
    && apt-get -y dist-upgrade \
    && apt-get install -y --no-install-recommends \
        bash \
        biber \
        ca-certificates \
        chktex \
        cm-super \
        curl \
        git \
        jq \
        latexmk \
        less \
        make \
        man-db \
        poppler-utils \
        python3-pip \
        ripgrep \
        shellcheck \
        sudo \
        tar \
        texlive-base \
        texlive-bibtex-extra \
        texlive-extra-utils \
        texlive-fonts-recommended \
        texlive-latex-base \
        texlive-latex-extra \
        texlive-latex-recommended \
        texlive-pictures \
        texlive-publishers \
        texlive-science \
        unzip \
    && echo "vscode ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers \
    && arch="$(dpkg --print-architecture)" \
    && case "${arch}" in \
        amd64) task_archive="task_linux_amd64.tar.gz"; gitleaks_archive="gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" ;; \
        arm64) task_archive="task_linux_arm64.tar.gz"; gitleaks_archive="gitleaks_${GITLEAKS_VERSION}_linux_arm64.tar.gz" ;; \
        *) echo "Unsupported architecture: ${arch}" >&2; exit 1 ;; \
      esac \
    && tmpdir="$(mktemp -d)" \
    && curl -fsSLo "${tmpdir}/${task_archive}" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/${task_archive}" \
    && curl -fsSLo "${tmpdir}/task_checksums.txt" "https://github.com/go-task/task/releases/download/v${TASK_VERSION}/task_checksums.txt" \
    && task_checksum_line="$(grep "${task_archive}" "${tmpdir}/task_checksums.txt")" \
    && if [ -z "${task_checksum_line}" ]; then echo "ERROR: Checksum not found for ${task_archive}" >&2; exit 1; fi \
    && (cd "${tmpdir}" && echo "${task_checksum_line}" | sha256sum -c -) \
    && mkdir -p /usr/local/libexec/polyglot-devcontainers \
    && tar -xzf "${tmpdir}/${task_archive}" -C /usr/local/libexec/polyglot-devcontainers task \
    && mv /usr/local/libexec/polyglot-devcontainers/task /usr/local/libexec/polyglot-devcontainers/task-real \
    && curl -fsSLo "${tmpdir}/${gitleaks_archive}" "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/${gitleaks_archive}" \
    && curl -fsSLo "${tmpdir}/gitleaks_checksums.txt" "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_checksums.txt" \
    && gitleaks_checksum_line="$(grep "${gitleaks_archive}" "${tmpdir}/gitleaks_checksums.txt")" \
    && if [ -z "${gitleaks_checksum_line}" ]; then echo "ERROR: Checksum not found for ${gitleaks_archive}" >&2; exit 1; fi \
    && (cd "${tmpdir}" && echo "${gitleaks_checksum_line}" | sha256sum -c -) \
    && tar -xzf "${tmpdir}/${gitleaks_archive}" -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks \
    && python3 -m pip install --break-system-packages --no-cache-dir "pre-commit==${PRE_COMMIT_VERSION}" \
    && bash /tmp/install_runtime_docs.sh /tmp/runtime-docs \
    && mkdir -p /workspace \
    && chown vscode:vscode /workspace \
    && rm -rf "${tmpdir}" /tmp/install_runtime_docs.sh /tmp/runtime-docs /var/lib/apt/lists/*

USER vscode
WORKDIR /workspace
